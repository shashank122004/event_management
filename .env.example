# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration (PostgreSQL/Supabase)
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=event_management_db

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_EXPIRY=24h

# Optional: Rate Limiting (for production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Razorpay Configuration (disabled — manual QR flow is active)
# RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX
# RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Google Apps Script Email API
APPS_SCRIPT_BASE_URL=https://script.google.com/macros/s/your_script_id/exec
APPS_SCRIPT_API_KEY=your_apps_script_api_key_here

# Supabase Storage Configuration
# Used for payment screenshot uploads
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
RATE_LIMIT_MAX_REQUESTS=100